name: Test publish to GHCR midnightntwrk

on:
  push:
    branches:
      - SRE-1769/publish-to-midnightntwrk

permissions:
  contents: read
  packages: write
  id-token: write  # Required for keyless signing with Cosign

jobs:
  test-publish:
    runs-on: ubuntu-latest
    outputs:
      IMAGE_TAG: ${{ steps.tag.outputs.IMAGE_TAG }}
    steps:
      - name: Checkout
        uses: actions/checkout@de0fac2e4500dabe0009e67214ff5f5447ce83dd #v6.0.2

      - name: Login to GHCR
        uses: docker/login-action@c94ce9fb468520275223c153574b00df6fe4bcc9 #v3.7.0
        with:
          registry: ghcr.io
          username: MidnightCI
          password: ${{ secrets.MIDNIGHTCI_PACKAGES_WRITE }}

      - name: Install Cosign
        uses: sigstore/cosign-installer@faadad0cce49287aee09b3a48701e75088a2c6ad # v4.0.0

      - name: Create multi-arch and arch-specific images in midnightntwrk
        id: tag
        run: |
          # This mirrors the production approach in main.yml: create multi-arch
          # manifests from arch-specific images, not by copying an existing manifest.
          IMAGE_TAG="latest-main"
          echo "IMAGE_TAG=${IMAGE_TAG}" >> "$GITHUB_OUTPUT"

          for IMAGE in midnight-node midnight-node-toolkit; do
            SRC="ghcr.io/midnight-ntwrk/${IMAGE}:latest-main"
            DST="ghcr.io/midnightntwrk/${IMAGE}:${IMAGE_TAG}"

            # Extract per-architecture digests from the source manifest
            AMD64_DIGEST=$(docker buildx imagetools inspect "$SRC" --format '{{range .Manifest.Manifests}}{{if eq .Platform.Architecture "amd64"}}{{.Digest}}{{end}}{{end}}')
            ARM64_DIGEST=$(docker buildx imagetools inspect "$SRC" --format '{{range .Manifest.Manifests}}{{if eq .Platform.Architecture "arm64"}}{{.Digest}}{{end}}{{end}}')

            echo "Creating ${DST} from arch-specific digests:"
            echo "  amd64: ${AMD64_DIGEST}"
            echo "  arm64: ${ARM64_DIGEST}"

            # Create multi-arch manifest
            docker buildx imagetools create \
              --tag "$DST" \
              "ghcr.io/midnight-ntwrk/${IMAGE}@${AMD64_DIGEST}" \
              "ghcr.io/midnight-ntwrk/${IMAGE}@${ARM64_DIGEST}"

            # Create arch-specific tags (needed for SBOM attestation)
            docker buildx imagetools create \
              --tag "ghcr.io/midnightntwrk/${IMAGE}:${IMAGE_TAG}-amd64" \
              "ghcr.io/midnight-ntwrk/${IMAGE}@${AMD64_DIGEST}"

            docker buildx imagetools create \
              --tag "ghcr.io/midnightntwrk/${IMAGE}:${IMAGE_TAG}-arm64" \
              "ghcr.io/midnight-ntwrk/${IMAGE}@${ARM64_DIGEST}"
          done

      - name: Verify images were created
        run: |
          docker buildx imagetools inspect ghcr.io/midnightntwrk/midnight-node:latest-main
          docker buildx imagetools inspect ghcr.io/midnightntwrk/midnight-node-toolkit:latest-main

      - name: Sign images
        run: |
          source .github/scripts/sign-image.sh
          sign_with_retry "ghcr.io/midnightntwrk/midnight-node:latest-main"
          sign_with_retry "ghcr.io/midnightntwrk/midnight-node-toolkit:latest-main"

      - name: Wait for signature propagation
        run: |
          echo "Waiting 10s for signatures to propagate in registry..."
          sleep 10

      - name: Verify signatures
        run: |
          CERT_IDENTITY="https://github.com/midnightntwrk/midnight-node/.github/workflows/.*"
          OIDC_ISSUER="https://token.actions.githubusercontent.com"

          for IMAGE in midnight-node midnight-node-toolkit; do
            echo "=== Verifying ghcr.io/midnightntwrk/${IMAGE}:latest-main ==="
            cosign verify \
              --certificate-identity-regexp "$CERT_IDENTITY" \
              --certificate-oidc-issuer "$OIDC_ISSUER" \
              "ghcr.io/midnightntwrk/${IMAGE}:latest-main"
            echo "OK"
          done

          echo "All signatures verified!"

  sbom-scan-midnightntwrk-node:
    name: SBOM/Scan Node midnightntwrk (${{ matrix.arch }})
    needs: [test-publish]
    strategy:
      matrix:
        arch: [amd64, arm64]
    permissions:
      contents: read
      packages: write
      id-token: write
    uses: ./.github/workflows/sbom-scan-image.yml
    with:
      image: ghcr.io/midnightntwrk/midnight-node:${{ needs.test-publish.outputs.IMAGE_TAG }}-${{ matrix.arch }}
      sbom-artifact-name: sbom-midnight-node-midnightntwrk-${{ matrix.arch }}
      platform: linux/${{ matrix.arch }}
      multi-arch-image: ghcr.io/midnightntwrk/midnight-node:${{ needs.test-publish.outputs.IMAGE_TAG }}
    secrets: inherit

  sbom-scan-midnightntwrk-toolkit:
    name: SBOM/Scan Toolkit midnightntwrk (${{ matrix.arch }})
    needs: [test-publish]
    strategy:
      matrix:
        arch: [amd64, arm64]
    permissions:
      contents: read
      packages: write
      id-token: write
    uses: ./.github/workflows/sbom-scan-image.yml
    with:
      image: ghcr.io/midnightntwrk/midnight-node-toolkit:${{ needs.test-publish.outputs.IMAGE_TAG }}-${{ matrix.arch }}
      sbom-artifact-name: sbom-midnight-node-toolkit-midnightntwrk-${{ matrix.arch }}
      platform: linux/${{ matrix.arch }}
      multi-arch-image: ghcr.io/midnightntwrk/midnight-node-toolkit:${{ needs.test-publish.outputs.IMAGE_TAG }}
    secrets: inherit

  verify-multiarch-attestation:
    name: Verify multi-arch SBOM attestation
    needs: [test-publish, sbom-scan-midnightntwrk-node, sbom-scan-midnightntwrk-toolkit]
    runs-on: ubuntu-latest
    permissions:
      contents: read
      packages: read
      id-token: write
    steps:
      - name: Install Cosign
        uses: sigstore/cosign-installer@faadad0cce49287aee09b3a48701e75088a2c6ad # v4.0.0

      - name: Login to GHCR
        uses: docker/login-action@c94ce9fb468520275223c153574b00df6fe4bcc9 #v3.7.0
        with:
          registry: ghcr.io
          username: MidnightCI
          password: ${{ secrets.MIDNIGHTCI_PACKAGES_WRITE }}

      - name: Verify SBOM attestation on multi-arch tags
        run: |
          CERT_IDENTITY="https://github.com/midnightntwrk/midnight-node/.github/workflows/.*"
          OIDC_ISSUER="https://token.actions.githubusercontent.com"

          for IMAGE in midnight-node midnight-node-toolkit; do
            echo "=== Verifying SBOM attestation for ghcr.io/midnightntwrk/${IMAGE}:${{ needs.test-publish.outputs.IMAGE_TAG }} ==="
            cosign verify-attestation --type spdxjson \
              --certificate-identity-regexp "$CERT_IDENTITY" \
              --certificate-oidc-issuer "$OIDC_ISSUER" \
              "ghcr.io/midnightntwrk/${IMAGE}:${{ needs.test-publish.outputs.IMAGE_TAG }}" > /dev/null
            echo "OK"
          done

          echo "All multi-arch SBOM attestations verified!"
